{
  "manifest_version": 3,
  "name": "Ask the Pandit",
  "description": "A Chrome extension that adds a floating Bhagavad-gita guidance chat interface to any webpage.",
  "version": "1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://vedantrupwal-ask-the-pandit.hf.space/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Open Ask the Pandit"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-pandit": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Toggle the Ask the Pandit panel"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}